---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Tasin's Personal Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-C5DPHPMGN8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-C5DPHPMGN8');
    </script>
  </head>
  <body class="min-h-screen bg-background schematic-bg flex flex-col relative overflow-x-hidden">
    
    <!-- Subtle fade out at the top/bottom for the grid -->
    <div class="fixed inset-0 pointer-events-none bg-gradient-to-b from-background via-transparent to-background z-[-1]"></div>
    
    <header class="w-full max-w-4xl mx-auto px-6 py-12 flex justify-between items-center z-10">
      <a href="/" class="text-xl font-bold font-mono tracking-tight group flex items-center gap-2">
        <span class="text-accent group-hover:animate-pulse">ts</span>
        <span class="text-muted group-hover:text-foreground transition-colors">/</span>
      </a>
      <nav class="flex gap-6 text-sm font-mono text-muted">
        <a href="/" class="hover:text-accent transition-colors">Home</a>
        <a href="/projects/atlasdesk" class="hover:text-accent transition-colors">AtlasDesk</a>
        <a href="/resume" class="hover:text-accent transition-colors">Resume</a>
        <a href="/about" class="hover:text-accent transition-colors">About</a>
      </nav>
    </header>

    <main class="flex-grow w-full max-w-4xl mx-auto px-6 z-10">
      <slot />
    </main>

    <footer class="w-full max-w-4xl mx-auto px-6 py-12 mt-24 border-t border-border/50 text-sm font-mono text-muted z-10">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <p>&copy; {new Date().getFullYear()} Tasin (K.M. Khalid Saifullah)</p>
        <div class="flex gap-4">
          <a href="mailto:tsaifullah25@gmail.com" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Email</a>
          <a href="https://www.linkedin.com/in/k-tasin/" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn</a>
          <a href="https://github.com/t-tasin" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
